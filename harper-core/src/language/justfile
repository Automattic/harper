# Harper Language Development Recipes
# =====================================
# All recipes work for standard languages (german, portuguese, slovak, etc.)
# NOTE: English is a special case - these recipes do not work for English

# Build the language testing framework
language-build:
	cd harper-core/src/language/testing_framework && cargo build --release

# Test text for any language (without recompiling)
# Usage: just language-test german "your text here"
language-test language text:
	if [ ! -f "harper-core/src/language/testing_framework/target/release/harper-lang-test" ]; then just language-build; fi
	harper-core/src/language/testing_framework/target/release/harper-lang-test \
		--language "{{language}}" \
		--dict "harper-core/src/language/{{language}}/dictionary.dict" \
		--annotations "harper-core/src/language/{{language}}/annotations.json" \
		--text "{{text}}"

# Full analysis for a specific language (validate + test + analyze)
language-analyze language:
	just language-build
	echo "Analyzing {{language}} language..."
	# Check dictionary word count
	wc -l harper-core/src/language/{{language}}/dictionary.dict
	# Check annotations
	jq '. | length' harper-core/src/language/{{language}}/annotations.json 2>/dev/null || echo "annotations.json not found or invalid JSON"
	# Test basic text
	just language-test {{language}} "test text"

# Validate all language dictionaries
language-validate-all:
	for lang in german portuguese slovak; do
		if [ -f "harper-core/src/language/${lang}/dictionary.dict" ]; then
			echo "Validating ${lang} dictionary..."
			wc -l harper-core/src/language/${lang}/dictionary.dict
		fi
	done

# Test all standard languages
language-test-all:
	for lang in german portuguese slovak; do
		if [ -f "harper-core/src/language/${lang}/dictionary.dict" ]; then
			echo "Testing ${lang}..."
			just language-test ${lang} "test text for ${lang}"
		fi
	done

# Full check (validate + test + analyze all languages)
language-full-check:
	just language-validate-all
	just language-test-all
	just language-analyze german

# Clean build artifacts
language-clean:
	rm -rf harper-core/src/language/testing_framework/target

# Run Rust tests for a specific language module
language-rust-test language:
	cargo test -p harper-core --lib --features {{language}} -- language::{{language}}

# Run all Rust tests for standard languages
language-rust-test-all:
	for lang in german portuguese slovak; do
		echo "Running Rust tests for ${lang}..."
		cargo test -p harper-core --lib --features ${lang} -- language::${lang} 2>&1 | grep -E "(test |passed|failed)"
	done

# Legacy aliases
language-german-test text:
	just language-test german "{{text}}"

language-build-lang-test:
	just language-build

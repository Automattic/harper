# frozen_string_literal: true

UI.user_error!('Please run fastlane via `bundle exec`') unless FastlaneCore::Helper.bundler?

APPLE_TEAM_ID = 'PZYM8XX95Q'

GITHUB_REPO = 'Automattic/harper'

TAURI_CONFIG_PATH = File.expand_path('../harper-desktop/src-tauri/tauri.conf.json', __dir__)

CODE_SIGNING_STORAGE_OPTIONS = {
  storage_mode: 's3',
  s3_bucket: 'a8c-fastlane-match',
  s3_region: 'us-east-2'
}.freeze

CODE_SIGNING_ENV_VARS = %w[
  MATCH_S3_ACCESS_KEY
  MATCH_S3_SECRET_ACCESS_KEY
  MATCH_PASSWORD
].freeze

ASC_API_KEY_ENV_VARS = %w[
  APP_STORE_CONNECT_API_KEY_KEY_ID
  APP_STORE_CONNECT_API_KEY_ISSUER_ID
  APP_STORE_CONNECT_API_KEY_KEY
].freeze

require 'json'
require 'tempfile'
require 'fastlane/plugin/wpmreleasetoolkit'

# Convenience alias — wpmreleasetoolkit 14.4+ namespaces this under
# Fastlane::Wpmreleasetoolkit but exposes no top-level shortcut.
EnvManager = Fastlane::Wpmreleasetoolkit::EnvManager

before_all do
  # Ensures match works correctly in CI by setting up a temporary keychain.
  # No-op locally, so safe to run unconditionally.
  setup_ci

  # No `.env` file in this repo today — env vars come from the Buildkite agent.
  # `set_up` still needed so EnvManager has a configured instance.
  EnvManager.set_up(env_file_name: 'harper-desktop.env')
end

desc 'Fetch the Developer ID Application certificate into the keychain'
lane :set_up_signing do |readonly: true|
  CODE_SIGNING_ENV_VARS.each { |k| EnvManager.get_required_env!(k) }
  ASC_API_KEY_ENV_VARS.each { |k| EnvManager.get_required_env!(k) } unless readonly

  sync_code_signing(
    type: 'developer_id',
    platform: 'macos',
    team_id: APPLE_TEAM_ID,
    # Developer ID cert is team-wide; no per-app storage key needed.
    app_identifier: [],
    api_key: readonly ? nil : app_store_connect_api_key,
    readonly: readonly,
    **CODE_SIGNING_STORAGE_OPTIONS
  )
end

desc 'Submit a signed .app or .dmg to Apple for notarization and staple the ticket'
lane :notarize_macos do |package:|
  ASC_API_KEY_ENV_VARS.each { |k| EnvManager.get_required_env!(k) }

  # `bundle_id` is required by the action for validation, even
  # though notarytool itself doesn't need it. For .app the
  # action would auto-read it from Info.plist; for .dmg we must
  # supply it.
  bundle_id = JSON.parse(File.read(TAURI_CONFIG_PATH)).fetch('identifier')

  notarize(
    package: package,
    bundle_id: bundle_id,
    api_key: app_store_connect_api_key,
    print_log: true
  )
end

desc 'Create a draft GitHub release for harper-desktop with the signed/notarized macOS artifacts attached'
lane :create_desktop_github_release do |tag:, dmg:, app_tarball:, app_signature:|
  EnvManager.get_required_env!('GITHUB_TOKEN')

  # `create_github_release` is create-only — a re-run on an existing tag
  # requires deleting the partial draft on GitHub before retrying.

  # `create_github_release` crashes with a FrozenError when no notes path is
  # given (wpmreleasetoolkit 14.6.0 calls `gsub!` on a frozen empty literal).
  # Pass an empty tempfile to get the action's intended "no notes" behavior.
  empty_notes = Tempfile.new(['release-notes', '.md'])
  empty_notes.close

  create_github_release(
    repository: GITHUB_REPO,
    version: tag,
    release_assets: [dmg, app_tarball, app_signature],
    release_notes_file_path: empty_notes.path,
    is_draft: true
  )
end
